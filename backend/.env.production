# Backend Production Environment Variables
# COPY THIS TO .env FILE AFTER GENERATING VALUES

# ===== SECURITY =====
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=GENERATE-AND-PASTE-HERE-min-32-chars

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ===== DATABASE =====
# For production, use PostgreSQL instead of SQLite
# Format: postgresql://username:password@hostname:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/llmagik

# Or use SQLite (not recommended for production)
# DATABASE_URL=sqlite:///./llmagik.db

# ===== AI PROVIDER =====
# Options: mock | openai | anthropic
AI_PROVIDER=mock

# OpenAI Configuration (if using openai)
# Get key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-PASTE-YOUR-KEY-HERE

# Anthropic Configuration (if using anthropic)
ANTHROPIC_API_KEY=sk-ant-PASTE-YOUR-KEY-HERE

# ===== CORS CONFIGURATION =====
# Allow your GitHub Pages URL
CORS_ORIGINS=["https://your-username.github.io/LLMagik", "https://your-domain.com"]

# ===== LOGGING =====
LOG_LEVEL=info
