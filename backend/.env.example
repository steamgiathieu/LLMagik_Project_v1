# Backend Environment Variables (template)
# Copy to .env and use .env as the single source of truth.

SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
DATABASE_URL=sqlite:///./app.db
# AI Provider Configuration
# Options: mock | openai | openrouter | anthropic | groq
AI_PROVIDER=mock

# OpenAI Configuration (if using openai provider)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# OpenRouter Configuration (if using openrouter provider)
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=http://localhost:5173
OPENROUTER_APP_NAME=LLMagik

# Anthropic Configuration (if using anthropic provider)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-3-haiku-20240307

# Groq Configuration (if using groq provider)
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.1-8b-instant
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_TIMEOUT_SECONDS=45

# CORS Configuration
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]

# Optional MongoDB Atlas (for snapshot/history mirror)
# Keep DATABASE_URL for SQLAlchemy app data. Mongo is used as secondary store.
# IMPORTANT: URL-encode special chars in password (e.g. ":" -> %3A, ")" -> %29).
MONGODB_URI=mongodb+srv://mdinh192:<minhdinhvippro123:))>@md.g3oy6w5.mongodb.net/?appName=md
MONGODB_DB_NAME = md
