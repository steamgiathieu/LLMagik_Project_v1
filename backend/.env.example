# Backend Environment Variables (template)
# Copy to .env and use .env as the single source of truth.

SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
DATABASE_URL=sqlite:///./app.db
# AI Provider Configuration
# Options: mock | openai | anthropic | others
AI_PROVIDER=mock

# OpenAI Configuration (if using openai provider)
OPENAI_API_KEY=your-openai-api-key-here

# Anthropic Configuration (if using anthropic provider)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# CORS Configuration
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]

# Optional MongoDB Atlas (for snapshot/history mirror)
# Keep DATABASE_URL for SQLAlchemy app data. Mongo is used as secondary store.
# IMPORTANT: URL-encode special chars in password (e.g. ":" -> %3A, ")" -> %29).
MONGODB_URI=
MONGODB_DB_NAME=llmagik
